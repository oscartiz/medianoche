#!/bin/bash

source "$HOME/.config/sketchybar/colors.sh"

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

##### Bar appearance #####
sketchybar --bar \
    height=33 \
    notch_width=200 \
    blur_radius=30 \
    position=top \
    sticky=on \
    padding_left=12 \
    padding_right=12 \
    color=$BG \
    border_width=0 \
    margin=0 \
    corner_radius=0 \
    y_offset=0

##### Global defaults — keep icon and label baselines aligned #####
sketchybar --default \
    updates=when_shown \
    icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
    icon.color=$FG \
    icon.padding_left=10 \
    icon.padding_right=6 \
    icon.y_offset=0 \
    label.font="JetBrainsMono Nerd Font:Semibold:12.0" \
    label.color=$FG \
    label.padding_left=0 \
    label.padding_right=10 \
    label.y_offset=1 \
    background.color=$BG_ALT \
    background.corner_radius=7 \
    background.height=20 \
    background.padding_left=4 \
    background.padding_right=4

##### LEFT — Apple logo + focused app #####
sketchybar --add item apple.logo left \
    --set apple.logo \
        icon="" \
        icon.color=$BLUE \
        icon.font="JetBrainsMono Nerd Font:Bold:15.0" \
        icon.padding_left=6 \
        icon.padding_right=6 \
        background.drawing=off \
        label.drawing=off

##### SPACES — AeroSpace workspaces (left, after the apple) #####
sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all); do
    sketchybar --add item space.$sid left \
        --set space.$sid \
            icon="$sid" \
            icon.font="JetBrainsMono Nerd Font:Bold:13.0" \
            icon.padding_left=10 \
            icon.padding_right=4 \
            label.font="JetBrainsMono Nerd Font:Semibold:13.0" \
            label.padding_left=0 \
            label.padding_right=10 \
            background.height=20 \
            background.corner_radius=7 \
            background.drawing=off \
            script="$PLUGIN_DIR/aerospace.sh $sid" \
            click_script="aerospace workspace $sid" \
        --subscribe space.$sid aerospace_workspace_change front_app_switched
done

sketchybar --add item front_app left \
    --set front_app \
        script="$PLUGIN_DIR/front_app.sh" \
        icon.drawing=off \
        background.color=$BG_ALT \
        label.color=$FG \
        label.font="JetBrainsMono Nerd Font:Bold:12.0" \
        label.padding_left=12 \
        label.padding_right=12 \
    --subscribe front_app front_app_switched

##### RIGHT — system stats (added right-to-left, so clock ends up leftmost) #####
sketchybar --add item battery right \
    --set battery \
        update_freq=60 \
        script="$PLUGIN_DIR/battery.sh" \
        icon.color=$GREEN \
        background.color=$BG_ALT \
    --subscribe battery system_woke power_source_change

sketchybar --add item volume right \
    --set volume \
        script="$PLUGIN_DIR/volume.sh" \
        icon.color=$BLUE \
        background.color=$BG_ALT \
    --subscribe volume volume_change

sketchybar --add item wifi right \
    --set wifi \
        update_freq=30 \
        script="$PLUGIN_DIR/wifi.sh" \
        icon.color=$AQUA \
        background.color=$BG_ALT \
    --subscribe wifi wifi_change

sketchybar --add item kbd right \
    --set kbd \
        update_freq=2 \
        script="$PLUGIN_DIR/kbd.sh" \
        icon="" \
        icon.color=$MAGENTA \
        background.color=$BG_ALT

sketchybar --add item cpu right \
    --set cpu \
        update_freq=5 \
        script="$PLUGIN_DIR/cpu.sh" \
        icon="" \
        icon.color=$ORANGE \
        background.color=$BG_ALT

sketchybar --add item claude_usage right \
    --set claude_usage \
        update_freq=60 \
        script="$PLUGIN_DIR/claude_usage.sh" \
        icon="󰚩" \
        icon.color=$PURPLE \
        background.color=$BG_ALT

sketchybar --add item clock right \
    --set clock \
        update_freq=10 \
        script="$PLUGIN_DIR/clock.sh" \
        icon="" \
        icon.color=$YELLOW \
        background.color=$BG_ALT

##### Finalize #####
sketchybar --update
sketchybar --trigger aerospace_workspace_change

echo "sketchybar config loaded"
