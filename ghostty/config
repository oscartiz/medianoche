# Midnight Blue theme — matches MacBook Air Midnight
background = #0f1322
foreground = #c8d3e6
cursor-color = #4d85ff
selection-background = #263554
selection-foreground = #c8d3e6

# ANSI palette
palette = 0=#0f1322
palette = 1=#e86e6e
palette = 2=#3dd68c
palette = 3=#f0c060
palette = 4=#4d85ff
palette = 5=#c07ec8
palette = 6=#5ecfef
palette = 7=#c8d3e6
palette = 8=#1f2a44
palette = 9=#f09090
palette = 10=#65e8a8
palette = 11=#f5d080
palette = 12=#7aaeff
palette = 13=#d4a0dc
palette = 14=#88dff5
palette = 15=#e4ecf5

font-family = JetBrainsMono Nerd Font
font-size = 14
font-feature = +liga
font-feature = +calt
font-thicken = true

background-opacity = 0.78
background-blur-radius = 40

window-padding-x = 18
window-padding-y = 18
window-padding-balance = true
window-decoration = true
macos-titlebar-style = hidden
window-save-state = always

cursor-style = block
cursor-style-blink = false
shell-integration-features = cursor,sudo,title

mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false

macos-option-as-alt = true
